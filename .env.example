# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# GitHub Personal Access Token (PAT) with 'repo' scope (used by upload.ps1)
GITHUB_TOKEN=your_personal_access_token_here

# GitHub Repository in 'owner/repo' format
GITHUB_REPO=your_username/errand-boy

# ——— AWS (Phase 1 backend) ———
# Generated via aws/claude-in-chrome-prompt.md. Never commit the real .env.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
